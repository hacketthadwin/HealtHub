# YouTube Data API (for health videos)
YOUTUBE_API_KEY= youtube_api_key_here

# Payment and request limits
PAYMENT_WINDOW_HOURS= chosen_number_here
MAX_ACTIVE_REQUESTS= chosen_number_here

# App
NODE_ENV=production
PORT=5000