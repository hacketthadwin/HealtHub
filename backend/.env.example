DATABASE_URL= database_url_here
JWT_SECRET= jwt_secret_here
RAZORPAY_KEY_ID= razorpay_key_id_here
RAZORPAY_KEY_SECRET= razorpay_key_secret_here
GEMINI_API_KEY= gemini_api_key_here

# Cloudinary (for PDF/file uploads)
CLOUD_NAME= cloud_name_here
CLOUD_API_KEY= cloud_api_key_here
CLOUD_API_SECRET= cloud_api_secret_here

# Resend (email service)
RESEND_API_KEY= resend_api_key_here
